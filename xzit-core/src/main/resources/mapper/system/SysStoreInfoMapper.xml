<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.dao.mapper.SysStoreInfoMapper">

    <resultMap type="SysStoreInfo" id="SysStoreInfoResult">
            <result property="id" column="id"/>
            <result property="createTime" column="create_time"/>
            <result property="updateTime" column="update_time"/>
            <result property="createBy" column="create_by"/>
            <result property="updateBy" column="update_by"/>
            <result property="isValid" column="is_valid"/>
            <result property="remark" column="remark"/>
            <result property="ossKey" column="oss_key"/>
            <result property="url" column="url"/>
            <result property="sceneName" column="scene_name"/>
            <result property="objId" column="obj_id"/>
    </resultMap>

    <sql id="selectSysStoreInfoVo">
        select id, create_time, update_time, create_by, update_by, is_valid, remark, oss_key, url, scene_name, obj_id
        from sys_store_info
    </sql>

    <select id="selectSysStoreInfoList" parameterType="SysStoreInfo" resultMap="SysStoreInfoResult">
        <include refid="selectSysStoreInfoVo"/>
        <where>
                        <if test="isValid != null ">
                            and is_valid = #{isValid}
                        </if>
                        <if test="ossKey != null  and ossKey != ''">
                            and oss_key = #{ossKey}
                        </if>
                        <if test="url != null  and url != ''">
                            and url = #{url}
                        </if>
                        <if test="sceneName != null  and sceneName != ''">
                            and scene_name like concat('%', #{sceneName}, '%')
                        </if>
                        <if test="objId != null ">
                            and obj_id = #{objId}
                        </if>
            and is_valid = 0
        </where>
    </select>

    <select id="selectSysStoreInfoById" parameterType="Long"
            resultMap="SysStoreInfoResult">
            <include refid="selectSysStoreInfoVo"/>
            where id = #{id} and is_valid = 0
    </select>

    <insert id="insertSysStoreInfo" parameterType="SysStoreInfo" useGeneratedKeys="true"
            keyProperty="id">
        insert into sys_store_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
                    <if test="createTime != null">create_time,
                    </if>
                    <if test="updateTime != null">update_time,
                    </if>
                    <if test="createBy != null">create_by,
                    </if>
                    <if test="updateBy != null">update_by,
                    </if>
                    <if test="isValid != null">is_valid,
                    </if>
                    <if test="remark != null">remark,
                    </if>
                    <if test="ossKey != null">oss_key,
                    </if>
                    <if test="url != null">url,
                    </if>
                    <if test="sceneName != null">scene_name,
                    </if>
                    <if test="objId != null">obj_id,
                    </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
                    <if test="createTime != null">#{createTime},
                    </if>
                    <if test="updateTime != null">#{updateTime},
                    </if>
                    <if test="createBy != null">#{createBy},
                    </if>
                    <if test="updateBy != null">#{updateBy},
                    </if>
                    <if test="isValid != null">#{isValid},
                    </if>
                    <if test="remark != null">#{remark},
                    </if>
                    <if test="ossKey != null">#{ossKey},
                    </if>
                    <if test="url != null">#{url},
                    </if>
                    <if test="sceneName != null">#{sceneName},
                    </if>
                    <if test="objId != null">#{objId},
                    </if>
        </trim>
    </insert>

    <update id="updateSysStoreInfo" parameterType="SysStoreInfo">
        update sys_store_info
        <trim prefix="SET" suffixOverrides=",">
                    <if test="createTime != null">create_time =
                        #{createTime},
                    </if>
                    <if test="updateTime != null">update_time =
                        #{updateTime},
                    </if>
                    <if test="createBy != null">create_by =
                        #{createBy},
                    </if>
                    <if test="updateBy != null">update_by =
                        #{updateBy},
                    </if>
                    <if test="isValid != null">is_valid =
                        #{isValid},
                    </if>
                    <if test="remark != null">remark =
                        #{remark},
                    </if>
                    <if test="ossKey != null">oss_key =
                        #{ossKey},
                    </if>
                    <if test="url != null">url =
                        #{url},
                    </if>
                    <if test="sceneName != null">scene_name =
                        #{sceneName},
                    </if>
                    <if test="objId != null">obj_id =
                        #{objId},
                    </if>
        </trim>
        where id = #{id} and is_valid = 0
    </update>

    <delete id="deleteSysStoreInfoById" parameterType="Long">
        update sys_store_info set `is_valid` = 1 where id = #{id}
    </delete>

    <delete id="deleteSysStoreInfoByIds" parameterType="String">
        delete from sys_store_info where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>